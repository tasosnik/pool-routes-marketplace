{
  "name": "poolroute-os",
  "version": "0.1.0",
  "description": "PoolRoute OS - A mobile-friendly marketplace and management platform for pool service routes",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start": "cd backend && npm start",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && npm test",
    "test:e2e": "cd e2e && npm test",
    "test:e2e:headed": "cd e2e && npm run test:headed",
    "test:e2e:ui": "cd e2e && npm run test:ui",
    "test:coverage": "npm run test:coverage:frontend && npm run test:coverage:backend",
    "test:coverage:frontend": "cd frontend && npm run test:coverage",
    "test:coverage:backend": "cd backend && npm run test:coverage",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "seed": "cd backend && npm run seed",
    "dev:reset": "scripts/dev-reset.sh",
    "dev:health": "scripts/health-check.sh",
    "db:reset": "scripts/db-reset.sh",
    "dev:status": "node scripts/dev-manager.js status",
    "dev:restart": "node scripts/dev-manager.js restart",
    "dev:cleanup": "node scripts/dev-manager.js reset",
    "kill:ports": "node scripts/dev-manager.js kill-ports",
    "health:check": "node scripts/dev-manager.js health"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "PoolRoute OS Team",
  "license": "MIT",
  "dependencies": {
    "pg": "^8.20.0"
  }
}
