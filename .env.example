# =============================================================================
# PoolRoute OS Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# NEVER commit the actual .env file with real secrets to version control!

# =============================================================================
# Application Configuration
# =============================================================================
NODE_ENV=development
PORT=3001

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string
DATABASE_URL=postgresql://poolroute:development@localhost:5432/poolroute_dev

# =============================================================================
# Authentication Configuration
# =============================================================================
# JWT Secret - MUST be a cryptographically secure random string
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER use the default value in production!
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET_MINIMUM_32_CHARS

# JWT token expiration times
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# External Service Configuration
# =============================================================================
# Mapbox Access Token (Required for mapping functionality)
# Get your free token at: https://account.mapbox.com/access-tokens/
# Public tokens start with 'pk.'
MAPBOX_ACCESS_TOKEN=pk.your_actual_mapbox_public_token_here

# =============================================================================
# Cache Configuration (Optional)
# =============================================================================
# Redis connection string
REDIS_URL=redis://localhost:6379

# =============================================================================
# Frontend Configuration
# =============================================================================
# API URL for frontend to connect to backend
VITE_API_URL=http://localhost:3001

# Mapbox token for frontend (usually same as backend token)
VITE_MAPBOX_ACCESS_TOKEN=pk.your_actual_mapbox_public_token_here

# =============================================================================
# Security Notes
# =============================================================================
# 1. JWT_SECRET must be at least 32 characters and cryptographically random
# 2. Never use default/example values in production
# 3. Use different secrets for different environments
# 4. Rotate secrets regularly in production
# 5. Store production secrets in secure secret management systems
# 6. Use environment-specific configuration management

# =============================================================================
# Development vs Production
# =============================================================================
# Development:
# - Can use localhost URLs
# - Can use weaker secrets for local testing
# - Should not use production API keys
#
# Production:
# - MUST use strong, random secrets
# - MUST use HTTPS URLs where applicable
# - MUST use production API keys
# - SHOULD use environment variable injection via deployment platform